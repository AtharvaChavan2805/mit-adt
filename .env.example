# Environment variables template
# Copy this file to .env in both server and client directories
# and fill in the appropriate values

# Server (.env)
PORT=4000
MONGODB_URL=mongodb://mongo:27017/mit-adt
JWT_SECRET=your-secret-key-here
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
SENDER_EMAIL=noreply@mit-adt.com
SENDER_NAME=MIT-ADT Team

# Client (.env)
VITE_API_URL=http://localhost:4000
VITE_APP_NAME=MIT-ADT
